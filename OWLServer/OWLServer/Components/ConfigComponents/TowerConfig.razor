@using OWLServer.Services

@code {
    private void ControllingTowerChanged(Tower tower, string newControllingTowerID)
    {
        if (tower.IsControlled)
        {
            tower.IsControlled = false;
            tower.IsControlledByID = null;
            GameStateService.TowerManagerService.Towers[tower.IsControlledByID].ControllsTowerID.Remove(tower.MacAddress);
        }

        if (!String.IsNullOrEmpty(newControllingTowerID))
        {
            tower.IsControlled = true;
            tower.IsControlledByID = newControllingTowerID;
            GameStateService.TowerManagerService.Towers[newControllingTowerID].ControllsTowerID.Add(tower.MacAddress);
        }
    }
}
<RadzenStack Orientation="Orientation.Horizontal">
    <RadzenButton Text="Alle ausschalten" Click="@GameStateService.TowerManagerService.OffTowers"></RadzenButton>
    <RadzenButton Text="Alle zurücksetzen" Click="@GameStateService.TowerManagerService.ResetTowers"></RadzenButton>
    <RadzenButton Text="Ping All" Click="@GameStateService.TowerManagerService.PingAll"></RadzenButton>
    <RadzenButton Text="Refresh" Click="@rdGrid.RefreshDataAsync"></RadzenButton>

</RadzenStack>
<br/>
<RadzenDataGrid
    @ref="rdGrid"
    TItem="Tower"
    Data="GameStateService.TowerManagerService.Towers.Values"
    EditMode="DataGridEditMode.Single">
    <Columns>
        <RadzenDataGridColumn Title="ID" Property="@nameof(Tower.MacAddress)"></RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Name" Property="@nameof(Tower.Name)">
            <EditTemplate Context="tower">
                <RadzenTextBox @bind-Value="tower.Name"></RadzenTextBox>
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="MapBuchstabe" Property="@nameof(Tower.DisplayLetter)">
            <EditTemplate Context="tower">
                <RadzenTextBox @bind-Value="tower.DisplayLetter"></RadzenTextBox>
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="IP" Property="@nameof(Tower.IP)"></RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Zeit zum Einnehmen" Property="@nameof(Tower.TimeToCaptureInSeconds)">
            <EditTemplate Context="tower">
                <RadzenNumeric @bind-Value="tower.TimeToCaptureInSeconds"></RadzenNumeric>
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Multiplier" Property="@nameof(Tower.Multiplier)">
            <EditTemplate Context="tower">
                <RadzenNumeric @bind-Value="tower.Multiplier"></RadzenNumeric>
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="IsControlled" Property="@nameof(Tower.IsControlled)">
            <Template Context="tower">
                <RadzenCheckBox @bind-Value="tower.IsControlled" ReadOnly="true"/>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Controlling TowerID"
                              Property="@nameof(Tower.IsControlledByID)">
            <Template Context="tower">
                @tower.IsControlledByID
            </Template>

            <EditTemplate Context="tower">
                <RadzenDropDown TValue="string?" Value="@tower.IsControlledByID"
                                Data="GameStateService.TowerManagerService.Towers.Values.Where(t => t.MacAddress != tower.MacAddress).Select(t => t.MacAddress)"
                                Name="DropDownBindValue"
                                AllowClear="true"
                                Change="@(args => ControllingTowerChanged(tower, $"{args}"))">
                </RadzenDropDown>
            </EditTemplate>
        </RadzenDataGridColumn>
        
        <RadzenDataGridColumn Title="ResetAction">
            <Template Context="tower">
                <RadzenButton Click="tower.Reset" Icon="reset_focus"></RadzenButton>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="LastPing" Property="@nameof(Tower.LastPing)"></RadzenDataGridColumn>

        <RadzenDataGridColumn Context="order" Filterable="false" Sortable="false" TextAlign="TextAlign.Right"
                              Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
            <Template Context="order">
                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                              Size="ButtonSize.Medium" class="rz-my-1 rz-ms-1" Click="@(args => EditRow(order))"
                              @onclick:stopPropagation="true"/>
            </Template>
            <EditTemplate Context="order">
                <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                              Size="ButtonSize.Medium" Click="@((args) => CancelEdit(order))" aria-label="Save"/>
            </EditTemplate>
        </RadzenDataGridColumn>
    </Columns>

</RadzenDataGrid>