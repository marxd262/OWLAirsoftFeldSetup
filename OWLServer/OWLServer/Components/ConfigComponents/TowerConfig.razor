@using OWLServer.Services
@using OWLServer.Models

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">

    <RadzenCard Variant="Variant.Flat">
        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2">Alle Tower</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap=".5rem" Wrap="FlexWrap.Wrap">
            <RadzenButton Text="Alle ausschalten" Icon="power_off" ButtonStyle="ButtonStyle.Secondary"
                          Click="@GameStateService.TowerManagerService.OffTowers"/>
            <RadzenButton Text="Alle zurücksetzen" Icon="restart_alt" ButtonStyle="ButtonStyle.Warning"
                          Click="@GameStateService.TowerManagerService.ResetTowers"/>
            <RadzenButton Text="Ping All" Icon="network_ping" ButtonStyle="ButtonStyle.Info"
                          Click="@GameStateService.TowerManagerService.PingAll"/>
        </RadzenStack>
    </RadzenCard>

    @if (!GameStateService.TowerManagerService.Towers.Any())
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" AllowClose="false">
            Keine Tower registriert.
        </RadzenAlert>
    }
    else
    {
        <RadzenRow Gap="1rem">
            @foreach (var tower in GameStateService.TowerManagerService.Towers.Values)
            {
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
                    <RadzenCard Variant="Variant.Outlined"
                                Style="@($"border-left: 4px solid {tower.DisplaycolorAsHTML()}")">

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center"
                                     class="rz-mb-2">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap=".5rem">
                                <RadzenText TextStyle="TextStyle.H5" Style="margin:0">@tower.DisplayLetter</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;color:var(--rz-text-secondary-color)">@tower.Name</RadzenText>
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap=".5rem">
                                <RadzenBadge BadgeStyle="@(tower.TowerOnline ? BadgeStyle.Success : BadgeStyle.Secondary)"
                                             Text="@(tower.TowerOnline ? "● Online" : "○ Offline")"/>
                                <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@tower.CurrentColor.ToString()"/>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-3">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
                                MAC: @tower.MacAddress
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
                                IP: @tower.IP
                            </RadzenText>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Vertical" Gap=".5rem" class="rz-mb-3">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap=".5rem" Wrap="FlexWrap.Wrap">
                                <RadzenFormField Text="Name" Style="flex:2;min-width:120px">
                                    <RadzenTextBox @bind-Value="tower.Name"/>
                                </RadzenFormField>
                                <RadzenFormField Text="Map-Buchstabe" Style="flex:1;min-width:60px">
                                    <RadzenTextBox @bind-Value="tower.DisplayLetter" MaxLength="2"/>
                                </RadzenFormField>
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap=".5rem" Wrap="FlexWrap.Wrap">
                                <RadzenFormField Text="Zeit zum Einnehmen (s)" Style="flex:1;min-width:120px">
                                    <RadzenNumeric @bind-Value="tower.TimeToCaptureInSeconds" Min="1"/>
                                </RadzenFormField>
                                <RadzenFormField Text="Setzt zurück nach (s)" Style="flex:1;min-width:120px">
                                    <RadzenNumeric @bind-Value="tower.ResetsAfterInSeconds" Min="1"/>
                                </RadzenFormField>
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap=".5rem" Wrap="FlexWrap.Wrap">
                                <RadzenFormField Text="Multiplier" Style="flex:1;min-width:100px">
                                    <RadzenNumeric @bind-Value="tower.Multiplier"/>
                                </RadzenFormField>
                                <RadzenFormField Text="Wird kontrolliert von" Style="flex:2;min-width:140px">
                                    <RadzenDropDown TValue="string?"
                                                    Value="@tower.IsControlledByID"
                                                    Data="GameStateService.TowerManagerService.Towers.Values
                                                              .Where(t => t.MacAddress != tower.MacAddress)
                                                              .Select(t => t.MacAddress)"
                                                    AllowClear="true"
                                                    Placeholder="(keine)"
                                                    Change="@(args => ControllingTowerChanged(tower, $"{args}"))"/>
                                </RadzenFormField>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" Gap=".5rem">
                            <RadzenButton Text="Reset" Icon="restart_alt" ButtonStyle="ButtonStyle.Warning"
                                          Size="ButtonSize.Small" Click="@tower.Reset"/>
                            <RadzenButton Text="Ping" Icon="network_ping" ButtonStyle="ButtonStyle.Info"
                                          Size="ButtonSize.Small" Click="@tower.PingTower"/>
                        </RadzenStack>

                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>
    }

</RadzenStack>
