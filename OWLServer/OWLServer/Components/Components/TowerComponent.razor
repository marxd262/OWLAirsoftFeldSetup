<style>
    .tower_@Tower.ID {
        .rz-progressbar-circular-value {
            stroke: @Tower.GetHTMLColor !important;
        }
    }
</style>

<RadzenProgressBarCircular class="@($"tower_{@Tower.ID}")" Value="@(Tower.CaptureProgress * 100)"
                           Size="ProgressBarCircularSize.Medium" Style="@("stroke:" + @Tower.GetHTMLColor + ";")">
    <Template>
        <RadzenText TextStyle="TextStyle.DisplayH4">@Tower.DisplayLetter</RadzenText>
    </Template>
</RadzenProgressBarCircular>


@code {
    [Parameter] public required Tower Tower { get; set; }

}