<style>
    .@TowerClass {
        .rz-progressbar-circular-value {
            stroke: @Tower.DisplaycolorAsHTML() !important;
        }
        @(Smaller && !Editable ? "" : ".rz-progressbar-circular-background{fill: rgba(255,255,255,0.5);}")
    }
    .absoluteTower { position: absolute }
</style>

@if (Editable)
{
    <div @onclick="() => OnTowerClicked.InvokeAsync()"
         style="cursor:pointer;transform:scale(1.6);filter:drop-shadow(0 0 4px rgba(0,0,0,0.65));@(Tower.Location?.ToLocationString())">
        <RadzenProgressBarCircular class="@TowerClass"
            Value="@(Tower.GetDisplayProgress())"
            Size="ProgressBarCircularSize.Medium">
            <Template>
                <RadzenText TextAlign="TextAlign.Center" TextStyle="TextStyle.DisplayH4"
                    Style="@($"color: {ColorTranslator.ToHtml(FontColor)}; margin-top: 7px;")">
                    @Tower.DisplayLetter
                </RadzenText>
            </Template>
        </RadzenProgressBarCircular>
    </div>
}
else
{
    @if (ShowResetTimer && !Smaller)
    {
        <div style="@Tower.Location?.ToLocationString()">
            <div style="text-align:center;">
                <span style="color:white;font-size:10px;background:rgba(0,0,0,0.6);padding:1px 4px;border-radius:3px;line-height:1;">
                    @(Tower.CapturedAt.HasValue ? $"{Math.Max(0, Tower.ResetSecondsRemaining)}s" : $"{Tower.ResetsAfterInSeconds}s")
                </span>
            </div>
            <RadzenProgressBarCircular class="@TowerClass"
                style="filter:drop-shadow(0 0 4px rgba(0,0,0,0.65));"
                Value="@(!Tower.IsPressed && Tower.ResetSecondsRemaining >= 0 && Tower.ResetsAfterInSeconds > 0
                    ? (int)((double)Tower.ResetSecondsRemaining / Tower.ResetsAfterInSeconds * 100)
                    : Tower.GetDisplayProgress())"
                Size="ProgressBarCircularSize.Medium">
                <Template>
                    <RadzenText TextAlign="TextAlign.Center" TextStyle="TextStyle.DisplayH4"
                        Style="@($"color: {ColorTranslator.ToHtml(FontColor)}; margin-top: 7px;")">
                        @Tower.DisplayLetter
                    </RadzenText>
                </Template>
            </RadzenProgressBarCircular>
        </div>
    }
    else
    {
        <RadzenProgressBarCircular class="@TowerClass"
            style="@(Smaller ? "" : $"filter:drop-shadow(0 0 4px rgba(0,0,0,0.65));{Tower.Location?.ToLocationString()}")"
            Value="@(Tower.GetDisplayProgress())"
            Size="@(Smaller ? ProgressBarCircularSize.Small : ProgressBarCircularSize.Medium)">
            <Template>
                <RadzenText TextAlign="TextAlign.Center"
                    TextStyle="@(Smaller ? TextStyle.DisplayH6 : TextStyle.DisplayH4)"
                    Style="@($"color: {ColorTranslator.ToHtml(FontColor)}; margin-top: 7px;")">
                    @Tower.DisplayLetter
                </RadzenText>
            </Template>
        </RadzenProgressBarCircular>
    }
}

@code {
    [Parameter] public required Tower Tower { get; set; }
    [Parameter] public bool Smaller { get; set; }
    [Parameter] public bool Editable { get; set; }
    [Parameter] public Color FontColor { get; set; } = Color.Black;
    [Parameter] public EventCallback OnTowerClicked { get; set; }
    [Parameter] public bool ShowResetTimer { get; set; }

    private string TowerClass => $"tower_{Tower.MacAddress.Replace(":", "-")}";
}
