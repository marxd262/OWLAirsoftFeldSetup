
<RadzenArcGauge Style="width: 100%; height: 250px;">
    <RadzenArcGaugeScale Step="100" MinorStep="2" Radius=".3" Y="0.2" StartAngle="-160" EndAngle="160"  Margin="0" StrokeWidth="2">
        <RadzenArcGaugeScaleValue Value=@(Tower.CaptureProgress * 100) ShowValue=true >
            <Template Context="pointer">
                <RadzenStack AlignItems="AlignItems.Center" Gap="0" Style="margin-top: -50%;">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-m-0"><strong>@Tower.DisplayLetter</strong></RadzenText>
                </RadzenStack>
            </Template>
        </RadzenArcGaugeScaleValue>
    </RadzenArcGaugeScale>
</RadzenArcGauge>

@code {
    [Parameter]
    public required Tower Tower { get; set; }
}