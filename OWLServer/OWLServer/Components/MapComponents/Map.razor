@inject IJSRuntime _jsRuntime;
@inject ExternalTriggerService ExternalTriggerService
@inject GameStateService _GameStateService
@inject MapService _MapService
@using OWLServer.Models.GameModes
@using OWLServer.Models
@implements IDisposable

<style>
    #map{
        width: 100%;
        height: calc(100% - 90px);
        object-fit:fill;
    }
    @@keyframes flowDash {
        to { stroke-dashoffset: -8; }
    }
    .arrow-flow {
        stroke-dasharray: 5 3;
        animation: flowDash 1.6s linear infinite;
    }
</style>

<div style="position: relative">

    <img id="map" src="@_MapService.GetCurrentMapUrl()" @onclick="OnClickEvent"/>

    @* SVG overlay for tower dependency arrows.
       viewBox="0 0 100 100": explicit coordinate space matching normalized tower positions
       (Location.Left/Top are 0–1, multiplied by 100). SVG %-coordinates don't resolve
       reliably when the parent has no explicit height.
       preserveAspectRatio="none": scales non-uniformly to match the map image (object-fit:fill).
       pointer-events:none: click events fall through to the img below. *@
    <svg viewBox="0 0 100 100" preserveAspectRatio="none"
         style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible">

        @* Control relationship arrow overlay — shown when a Conquest game with ActiveControlLayout is running. *@
        <defs style="overflow:visible">
            <filter id="arrowGlow" filterUnits="userSpaceOnUse" x="-10" y="-10" width="120" height="120">
                <feGaussianBlur in="SourceGraphic" stdDeviation="1.5" result="blur"/>
                <feMerge>
                    <feMergeNode in="blur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
            @foreach (var src in ControllerTowers)
            {
                <marker id="arrow-@src.MacAddress"
                        markerWidth="6" markerHeight="5" refX="0" refY="2.5"
                        orient="auto" markerUnits="userSpaceOnUse">
                    <polygon points="0 0, 6 2.5, 0 5" fill="@ArrowColor(src)" />
                </marker>
            }
        </defs>

        @foreach (var link in ActiveControlLinks)
        {
            var src = _GameStateService.TowerManagerService.Towers.Values
                .FirstOrDefault(t => t.MacAddress == link.ControllerTowerMacAddress && t.Location != null);
            var dst = _GameStateService.TowerManagerService.Towers.Values
                .FirstOrDefault(t => t.MacAddress == link.ControlledTowerMacAddress && t.Location != null);

            if (src != null && dst != null)
            {
                var (ax1, ay1, ax2, ay2) = ArrowLine(src, dst);
                <line x1="@ax1" y1="@ay1" x2="@ax2" y2="@ay2"
                      stroke="@ArrowColor(src)"
                      stroke-width="2"
                      class="arrow-flow"
                      filter="url(#arrowGlow)"
                      marker-end="url(#arrow-@src.MacAddress)" />
            }
        }

        @* Chain link overlay — only visible in ChainBreak mode.
           Arrow color reflects the source tower's team: red/blue = that team can advance,
           grey = path locked or neutral. *@
        @if (IsChainBreakActive)
        {
            <defs>
                <marker id="chain-arrow-red" markerWidth="6" markerHeight="5" refX="0" refY="2.5"
                        orient="auto" markerUnits="userSpaceOnUse">
                    <polygon points="0 0, 6 2.5, 0 5" fill="#fc1911"/>
                </marker>
                <marker id="chain-arrow-blue" markerWidth="6" markerHeight="5" refX="0" refY="2.5"
                        orient="auto" markerUnits="userSpaceOnUse">
                    <polygon points="0 0, 6 2.5, 0 5" fill="#00b4f1"/>
                </marker>
                <marker id="chain-arrow-grey" markerWidth="6" markerHeight="5" refX="0" refY="2.5"
                        orient="auto" markerUnits="userSpaceOnUse">
                    <polygon points="0 0, 6 2.5, 0 5" fill="#555555"/>
                </marker>
            </defs>

            @foreach (var link in ActiveChainLinks)
            {
                var srcTower = _GameStateService.TowerManagerService.Towers.Values
                    .FirstOrDefault(t => t.MacAddress == link.FromTowerMacAddress && t.Location != null);
                var dstTower = _GameStateService.TowerManagerService.Towers.Values
                    .FirstOrDefault(t => t.MacAddress == link.ToTowerMacAddress && t.Location != null);

                @if (srcTower != null && dstTower != null)
                {
                    @if (link.IsBidirectional)
                    {
                        @* Draw two offset arrows — one each direction — so players see both teams' advance path *@
                        var (fx1, fy1, fx2, fy2) = ArrowLine(srcTower, dstTower, srcGap: 3.0, destGap: 9.0, perpOffset: 1.2);
                        var (rx1, ry1, rx2, ry2) = ArrowLine(dstTower, srcTower, srcGap: 3.0, destGap: 9.0, perpOffset: 1.2);
                        var fwdColor  = ChainLinkColorForTower(srcTower);
                        var revColor  = ChainLinkColorForTower(dstTower);
                        var fwdMarker = ChainMarkerIdForTower(srcTower);
                        var revMarker = ChainMarkerIdForTower(dstTower);
                        <line x1="@fx1" y1="@fy1" x2="@fx2" y2="@fy2"
                              stroke="@fwdColor" stroke-width="2" stroke-dasharray="4 2"
                              marker-end="url(#@fwdMarker)" filter="url(#arrowGlow)"/>
                        <line x1="@rx1" y1="@ry1" x2="@rx2" y2="@ry2"
                              stroke="@revColor" stroke-width="2" stroke-dasharray="4 2"
                              marker-end="url(#@revMarker)" filter="url(#arrowGlow)"/>
                    }
                    else
                    {
                        var (ax1, ay1, ax2, ay2) = ArrowLine(srcTower, dstTower);
                        var linkColor  = ChainLinkColorForTower(srcTower);
                        var markerId   = ChainMarkerIdForTower(srcTower);
                        <line x1="@ax1" y1="@ay1" x2="@ax2" y2="@ay2"
                              stroke="@linkColor" stroke-width="2" stroke-dasharray="4 2"
                              marker-end="url(#@markerId)" filter="url(#arrowGlow)"/>
                    }
                }
            }
        }
    </svg>

    @foreach (var tower in _GameStateService.TowerManagerService.Towers.Values.Where(t => t.Location != null))
    {
        <TowerComponent Tower="tower"></TowerComponent>
    }

</div>

<script>
    function GetElementLocation(elementId) {
        var element = $(elementId);
        var position = element.position();
        var offset   = element.offset();
        return {
            Width:      element.outerWidth(),
            Height:     element.outerHeight(),
            offsetTop:  offset.top,
            offsetLeft: offset.left,
            Top:        position.top,
            Left:       position.left,
        };
    }
</script>

@code {

    // -------------------------------------------------------------------------
    // Parameters
    // -------------------------------------------------------------------------

    [Parameter] public List<Tower>         TowerListe { get; set; } = [];
    [Parameter] public List<ElementLocation> LocoListe { get; set; } = [];
    [Parameter] public Action<ElementLocation> Clicked { get; set; }

    // -------------------------------------------------------------------------
    // Map click → normalized (0–1) coordinates
    // -------------------------------------------------------------------------

    private async void OnClickEvent(MouseEventArgs args)
    {
        var result = await _jsRuntime.InvokeAsync<ElementLocation>("GetElementLocation", "#map");
        if (result != null)
        {
            result.Top  = (args.PageY - result.offsetTop)  / result.Height;
            result.Left = (args.PageX - result.offsetLeft) / result.Width;
            Clicked?.Invoke(result);
        }
    }

    // -------------------------------------------------------------------------
    // SVG arrow helpers
    // -------------------------------------------------------------------------

    // Controller towers with a Location from the ActiveControlLayout (Conquest mode).
    private IEnumerable<Tower> ControllerTowers
    {
        get
        {
            if (_GameStateService.CurrentGame is GameModeConquest cq && cq.ActiveControlLayout != null)
            {
                var controllerMacs = cq.ActiveControlLayout.Links
                    .Select(l => l.ControllerTowerMacAddress)
                    .ToHashSet();
                return _GameStateService.TowerManagerService.Towers.Values
                    .Where(t => t.Location != null && controllerMacs.Contains(t.MacAddress));
            }
            return Enumerable.Empty<Tower>();
        }
    }

    private IEnumerable<TowerControlLink> ActiveControlLinks
    {
        get
        {
            if (_GameStateService.CurrentGame is GameModeConquest cq && cq.ActiveControlLayout != null)
                return cq.ActiveControlLayout.Links;
            return Enumerable.Empty<TowerControlLink>();
        }
    }

    private bool IsChainBreakActive =>
        _GameStateService.CurrentGame is GameModeChainBreak cb
        && cb.ActiveChainLayout != null;

    private IEnumerable<ChainLink> ActiveChainLinks =>
        (_GameStateService.CurrentGame as GameModeChainBreak)
            ?.ActiveChainLayout?.Links
        ?? Enumerable.Empty<ChainLink>();

    // Arrow color for source tower in the existing ControllsTowerID overlay.
    private string ArrowColor(Tower src) => src.CurrentColor switch
    {
        TeamColor.RED  => "#fc1911",
        TeamColor.BLUE => "#00b4f1",
        _              => "#000000"
    };

    // Chain link color based on which team holds the source tower.
    private static string ChainLinkColorForTower(Tower src) => src.CurrentColor switch
    {
        TeamColor.RED  => "#fc1911",
        TeamColor.BLUE => "#00b4f1",
        _              => "#555555"   // grey = locked or uncaptured
    };

    private static string ChainMarkerIdForTower(Tower src) => src.CurrentColor switch
    {
        TeamColor.RED  => "chain-arrow-red",
        TeamColor.BLUE => "chain-arrow-blue",
        _              => "chain-arrow-grey"
    };

    /// <summary>
    /// Offsets both endpoints away from tower centers so the arrow doesn't overlap
    /// the circular marker. perpOffset shifts the line sideways (for parallel bidir arrows).
    /// Gap is in 0-100 SVG coordinate units.
    /// </summary>
    // destGap = srcGap (tower clearance) + arrowhead length (6 units in userSpaceOnUse)
    private static (string x1, string y1, string x2, string y2) ArrowLine(
        Tower src, Tower dst, double srcGap = 3.0, double destGap = 9.0, double perpOffset = 0.0)
    {
        double sx = src.Location!.Left * 100, sy = src.Location!.Top * 100;
        double ex = dst.Location!.Left * 100, ey = dst.Location!.Top * 100;
        double dx = ex - sx, dy = ey - sy;
        double len = Math.Sqrt(dx * dx + dy * dy);

        if (len < 0.001) return (Fmt(sx), Fmt(sy), Fmt(ex), Fmt(ey));

        double nx = dx / len, ny = dy / len;
        // perpendicular unit vector (rotated 90°)
        double px = -ny, py = nx;
        return (Fmt(sx + nx * srcGap  + px * perpOffset), Fmt(sy + ny * srcGap  + py * perpOffset),
                Fmt(ex - nx * destGap + px * perpOffset), Fmt(ey - ny * destGap + py * perpOffset));
    }
    /// <summary>
    /// InvariantCulture prevents locale decimal separators (e.g. German commas)
    /// from producing invalid SVG coordinate values that browsers silently coerce to 0.
    /// </summary>
    /// <param name="v"></param>
    /// <returns></returns>
    private static string Fmt(double v) =>
        v.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

    // -------------------------------------------------------------------------
    // Lifecycle
    // -------------------------------------------------------------------------

    private Action _stateChangedHandler = null!;

    protected override void OnInitialized()
    {
        _stateChangedHandler = () => InvokeAsync(StateHasChanged);
        ExternalTriggerService.StateHasChangedAction += _stateChangedHandler;
        base.OnInitialized();
    }

    public void Dispose()
    {
        ExternalTriggerService.StateHasChangedAction -= _stateChangedHandler;
    }
}
