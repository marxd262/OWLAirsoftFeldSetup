        <RadzenTabsItem Text="Startseite">
            <Home ShowGameEndOverlay="false"/>
        </RadzenTabsItem>
        <RadzenTabsItem Text="Spiel-Einstellungen">
            <AdminPanel/>
        </RadzenTabsItem>
