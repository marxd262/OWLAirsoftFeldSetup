        <RadzenTabsItem Text="Tower-Einstellungen">
            <TowerConfig/>
        </RadzenTabsItem>
        <RadzenTabsItem Text="Map-Einstellungen">
            <MapTests></MapTests>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>