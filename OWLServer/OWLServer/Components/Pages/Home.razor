@page "/"
@using System.Text.Json;
@using OWLServer.Services
@inject GameStateService GameStateService
@inject ExternalTriggerService ExternalTriggerService



<PageTitle>Home</PageTitle>

<MatchScoreBar TeamOnSide="@TeamOnSide"/>
<div style="margin-top:-40px">
<Map />
</div>
 <br/>

<RadzenCard Variant="Variant.Outlined" Style="background-color: yellow">
    <p>GameMode: @GameStateService.CurrentGame?.ToString()</p>
    <p>IsRunning: @GameStateService.CurrentGame?.IsRunning</p>
    <p>Timer: @GameStateService.CurrentGame?.GetTimer?.ToString(@"mm\:ss")</p>
    <p>Voraussichtlicher Sieger: @GameStateService.CurrentGame?.GetWinner</p>
</RadzenCard>
<br/>

@{
    Tower x = new Tower("0", "0");
    x.DisplayLetter = "B";
    x.CurrentColor = TeamColor.BLUE;
    x.CaptureProgress = .3;
    Tower y = new Tower("1", "0");
    y.DisplayLetter = "A";
    y.CurrentColor = TeamColor.NONE;
    y.CaptureProgress = .2;
    Tower z = new Tower("2", "0");
    z.DisplayLetter = "C";
    z.CaptureProgress = .5;
    z.CurrentColor = TeamColor.LOCKED;
    
    Tower a = new Tower("3", "0");
    a.DisplayLetter = "d";
    a.CaptureProgress = .9;
    a.CurrentColor = TeamColor.RED;
}
<TowerComponent Tower="@a"></TowerComponent>
<TowerComponent Tower="@x"></TowerComponent>
<TowerComponent Tower="@y"></TowerComponent>
<TowerComponent Tower="@z"></TowerComponent>

<br/> 
<RadzenCard Variant="Variant.Outlined" Style="background-color: yellow">
    <RadzenStack>
        <p>Alle Tower:</p> 
        @foreach (var tower in GameStateService.TowerManagerService.Towers.Values)
        {
            <p>@JsonSerializer.Serialize(tower)</p> 
        }
    </RadzenStack>
</RadzenCard>
 
@code{
    [Parameter] public TeamColor TeamOnSide { get; set; } = TeamColor.NONE;
    
    protected override void OnInitialized()
    {
        ExternalTriggerService.StateHasChangedAction += () => InvokeAsync(StateHasChanged);
        base.OnInitialized();
    }
}