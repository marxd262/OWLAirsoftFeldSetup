@using static OWLServer.Components.MapComponents.Map
@inject GameStateService _GameStateService
    <Map Clicked="MapClicked" />
<RadzenStack>
    <RadzenDropDown TValue="Tower" Data="_GameStateService.TowerManagerService.Towers.Values" Placeholder="Tower auswählen" @bind-Value="@selectedTower" />
    <RadzenButton Icon="Delete" Text="Tower neu platzieren" Click="BtnDeleteLocationClick" Visible="@(selectedTower != null)" />
</RadzenStack>

@code {
    Tower? selectedTower { get; set; }

    private void UpdateTower(ElementLocation? location)
    {
        if(selectedTower != null)
        {
            _GameStateService.TowerManagerService.Towers.ContainsKey(selectedTower.ID);
            selectedTower.Location = location;
        }
    }

    private void BtnDeleteLocationClick()
    {
        UpdateTower(null);

        StateHasChanged();
    }

    private void MapClicked(ElementLocation? location)
    {
        if (selectedTower?.Location == null && location != null)
        {
            UpdateTower(location);
        }

        StateHasChanged();
    }
}
