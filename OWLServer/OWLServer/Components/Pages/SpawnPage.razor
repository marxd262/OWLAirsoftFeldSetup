@page "/Spawn-{SpawnPlace}"
@using OWLServer.Services
@inject IExternalTriggerService ExternalTriggerService
@inject IGameStateService GameStateService
@implements IDisposable
<PageTitle>@PageTitle</PageTitle>

<Home TeamOnSide="@GetSpawnColor()"/>

@if ((!GameStateService.CurrentGame?.IsRunning ?? false) && (GameStateService.TeamSetReady))
{
    <RadzenToggleButton Text="@(SpawnReady ? "BEREIT!" : "Bereit setzen")"
                        @bind-Value=@SpawnReady
                        Change="@ToggleButtonClick"
                  
                        Size="ButtonSize.Large"
                        ButtonStyle="ButtonStyle.Danger"
                        ToggleButtonStyle="ButtonStyle.Success"
                        style="height: 120px;
                      width:150px; 
                      position: Absolute;
                      right: 1rem;
                      bottom: 1rem;
                      z-index: 9999;"/>
}

@if ((GameStateService.CurrentGame?.IsRunning ?? false) && (GameStateService.CurrentGame?.ShowRespawnButton ?? false))
{
    <RadzenButton Text="Respawn"
                  Click="() => { ExternalTriggerService.InvokeKlickerPressed(GetSpawnColor()); }"
                  Size="ButtonSize.Large"
                  ButtonStyle="ButtonStyle.Danger"
                  style="height: 120px;
                      width:150px; 
                      position: Absolute;
                      right: 1rem;
                      bottom: 1rem;"/>
}


@code {
    [Parameter]
    public string SpawnPlace { get; set; }

    private string PageTitle => $"Spawn {SpawnPlace}";

    private Action _stateChangedHandler = null!;

    public bool WaldSpawn => SpawnPlace == "Wald";
    public bool StadtSpawn => SpawnPlace == "Stadt";

    public bool SpawnReady
    {
        get
        {
            if (WaldSpawn)
                return GameStateService.WaldSpawnReady;
            if (StadtSpawn)
                return GameStateService.StadtSpawnReady;
            return false;
        }
        set
        {
            if (WaldSpawn)
                GameStateService.WaldSpawnReady = value;
            else if (StadtSpawn)
                GameStateService.StadtSpawnReady = value;
        }
    }
    
    public TeamColor GetSpawnColor() 
    {
        if (WaldSpawn)
            return GameStateService.TeamInWald;
        if(StadtSpawn)
            return GameStateService.TeamInStadt;
        return TeamColor.NONE;
    }
    
    protected override void OnInitialized()
    {
        _stateChangedHandler = () => InvokeAsync(StateHasChanged);
        ExternalTriggerService.StateHasChangedAction += _stateChangedHandler;
        base.OnInitialized();
    }

    public void Dispose()
    {
        ExternalTriggerService.StateHasChangedAction -= _stateChangedHandler;
    }

    private void ToggleButtonClick()
    {
        ExternalTriggerService.StateHasChangedAction();
    }
}